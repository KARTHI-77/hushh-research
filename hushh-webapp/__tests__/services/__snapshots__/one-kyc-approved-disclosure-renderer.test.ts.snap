exports[`buildApprovedDisclosureHtml — regression surface > matches the captured golden HTML for a plain draft (shell-extraction guard) 1`] = `"<div style="margin:0;padding:16px;background:#18181b;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;"><div style="width:100%;max-width:820px;margin:0 auto;border:1px solid #3f3f46;border-radius:18px;background:#242426;overflow:hidden;"><div style="padding:16px 20px;border-bottom:1px solid #3f3f46;background:#1f2023;"><table role="presentation" cellpadding="0" cellspacing="0" style="border-collapse:collapse;"><tr><td style="width:42px;vertical-align:middle;"><div style="width:34px;height:34px;border-radius:12px;border:1px solid #E7C969;background:#D4A847;color:#18181b;font-size:19px;line-height:34px;text-align:center;font-weight:800;">🤫</div></td><td style="vertical-align:middle;"><div style="font-size:14px;line-height:1.2;color:#f8fafc;font-weight:800;">hussh One</div><div style="margin-top:2px;font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:#D4A847;font-weight:750;">approved reply</div></td></tr></table></div><div style="padding:20px;"><p style="margin:0;color:#e5e7eb;font-size:15px;line-height:1.6;white-space:pre-wrap;">I am replying on behalf of Jane Doe.</p><div style="height:18px;line-height:18px;">&nbsp;</div><section style="margin:0;"><h1 style="margin:0;color:#f8fafc;font-size:24px;line-height:1.15;">Identity</h1><div style="height:14px;line-height:14px;">&nbsp;</div><section style="margin:0;"><h2 style="margin:0 0 10px;color:#f8fafc;font-size:17px;line-height:1.25;"></h2><table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;max-width:100%;border-collapse:collapse;table-layout:fixed;"><tbody><tr><td style="width:50%;padding:6px;vertical-align:top;word-break:break-word;"><div style="border:1px solid #3f3f46;border-radius:12px;background:#1f2023;padding:12px;"><div style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:#a1a1